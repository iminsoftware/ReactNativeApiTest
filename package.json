{
  "name": "react-native-imin-hardware",
  "version": "0.1.0",
  "description": "React Native plugin for iMin POS hardware devices",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "lib",
    "android",
    "!android/build",
    "!android/.gradle",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "typescript": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "prepare": "bob build",
    "release": "release-it"
  },
  "keywords": [
    "react-native",
    "imin",
    "pos",
    "hardware",
    "scanner",
    "nfc",
    "rfid"
  ],
  "repository": "https://github.com/iminsoftware/ReactNativeApiTest",
  "author": "iMin Software Team",
  "license": "MIT",
  "peerDependencies": {
    "react": "*",
    "react-native": ">=0.68.0"
  },
  "devDependencies": {
    "@react-native-community/eslint-config": "^3.2.0",
    "@types/react": "^18.0.0",
    "@types/react-native": "^0.73.0",
    "eslint": "^8.0.0",
    "prettier": "^2.8.0",
    "react": "18.2.0",
    "react-native": "0.73.0",
    "react-native-builder-bob": "^0.20.0",
    "release-it": "^15.0.0",
    "typescript": "^5.9.3"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
